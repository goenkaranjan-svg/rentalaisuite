### Existing app (Vite client)
# Set this to your Clerk sign-in URL (can be a route on your Next app).
# Example during local dev:
# VITE_CLERK_LOGIN_URL=http://localhost:3000/bridge
VITE_CLERK_LOGIN_URL=

# When true, visiting /login will automatically redirect to Clerk unless ?legacy=true is present.
VITE_USE_CLERK_LOGIN=false

### Server (Express)
# Used to verify Clerk session tokens and fetch user profile.
CLERK_SECRET_KEY=

### Next app (my-clerk-app)
# Where to send users after they sign in with Clerk.
# MAIN_APP_URL=http://localhost:5001
MAIN_APP_URL=

# Database Configuration
# PostgreSQL connection string
# For Docker: postgresql://postgres:postgres@localhost:5432/rental_ai_suite
# For local: postgresql://username:password@localhost:5432/database_name
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rental_ai_suite

# Session Configuration
# Generate a random secret for session encryption
# You can generate one with: openssl rand -base64 32
SESSION_SECRET=your-session-secret-here-change-this-in-production

# OIDC Authentication Configuration
# OIDC issuer URL (e.g., https://your-auth-provider.com/oidc)
ISSUER_URL=https://your-auth-provider.com/oidc
# Or use OIDC_ISSUER_URL instead
# OIDC_ISSUER_URL=https://your-auth-provider.com/oidc

# OIDC Client ID
CLIENT_ID=your-client-id-here

# Development-only auth bypass (never enable in production)
DEV_AUTH_BYPASS=false
# DEV_AUTH_BYPASS_USER_ID=dev-local-user
# DEV_AUTH_BYPASS_EMAIL=dev@localhost

# Auth Security / Verification
# Enforce verified email before login
REQUIRE_EMAIL_VERIFICATION=true
# Optional adaptive auth hardening
ENABLE_RISK_STEP_UP=true
# SESSION_IDLE_TIMEOUT_MS=1800000
# REQUIRE_CAPTCHA_ON_AUTH=false
# AUTH_ALLOW_COUNTRIES=US,CA
# AUTH_DENY_COUNTRIES=
# Enable passkey endpoint feature flags (full WebAuthn verification wiring required)
# ENABLE_PASSKEYS=false

# Auth Email Delivery (Resend)
AUTH_EMAIL_PROVIDER=resend
RESEND_API_KEY=re_3nyV8jEo_GKW52swk2CxZB1fdYdt5svbg
AUTH_EMAIL_FROM=no-reply@esourceincorp.com
PUBLIC_APP_URL=https://esourceincorp.com
RENT_OVERDUE_NOTIFICATION_DEFAULT_DAYS=5
LEASE_EXPIRY_NOTIFICATION_DEFAULT_DAYS=30
# Required in production if using /api/internal/jobs/rent-overdue-scan (for Vercel Cron or external scheduler)
# CRON_SECRET=replace-with-long-random-string

# OpenAI Configuration (Optional - for AI features)
# AI_INTEGRATIONS_OPENAI_API_KEY=your-openai-api-key
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Vendor discovery (Optional - Google Places provider)
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Assistant LLM Routing (Ollama-first)
ASSISTANT_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
# Optional fallback if primary provider is unavailable
ASSISTANT_FALLBACK_PROVIDER=openai
# Optional override when using OpenAI for assistant chat
# AI_ASSISTANT_MODEL=gpt-4.1-mini
# AI_ASSISTANT_EMBEDDING_MODEL=text-embedding-3-small

# Supabase Vector RAG (Optional - required for knowledge retrieval)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SECRET_KEY=your-supabase-secret-key
# SUPABASE_SERVICE_ROLE_KEY=legacy-fallback-key
# SUPABASE_DB_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
# SUPABASE_DB_PASSWORD=optional-if-you-want-script-to-derive-SUPABASE_DB_URL
# SUPABASE_VECTOR_RPC=match_knowledge_chunks
# SUPABASE_KNOWLEDGE_DOCUMENTS_TABLE=knowledge_documents
# SUPABASE_KNOWLEDGE_CHUNKS_TABLE=knowledge_chunks
# ASSISTANT_RAG_MATCH_COUNT=4
# ASSISTANT_RAG_MIN_SIMILARITY=0.65
# ASSISTANT_EMBEDDING_PROVIDER=ollama
# ASSISTANT_KNOWLEDGE_PATHS=SETUP.md,LAUNCH_SECURITY_CHECKLIST.md
# ASSISTANT_KNOWLEDGE_CHUNK_SIZE=1200
# ASSISTANT_KNOWLEDGE_CHUNK_OVERLAP=200

# Listing publish endpoints (Optional - for one-click syndication publishing)
# LISTING_PUBLISH_ZILLOW_URL=https://your-zillow-feed-endpoint.example.com/listings
# LISTING_PUBLISH_ZILLOW_API_KEY=your-zillow-api-key
# LISTING_PUBLISH_APARTMENTS_URL=https://your-apartments-endpoint.example.com/listings
# LISTING_PUBLISH_APARTMENTS_API_KEY=your-apartments-api-key

# Multifamily for-sale API (Optional - required for /investor/multifamily live data)
# RENTCAST_API_KEY=your-rentcast-api-key
# RENTCAST_BASE_URL=https://api.rentcast.io/v1

# Server Configuration
PORT=5001

# Local HTTPS development (optional - enables secure-context browser APIs like microphone on localhost)
# Generate certs with mkcert:
#   mkcert -cert-file localhost.pem -key-file localhost-key.pem localhost 127.0.0.1 ::1
# Then set absolute paths to those files:
# DEV_HTTPS_CERT_PATH=/Users/you/path/to/localhost.pem
# DEV_HTTPS_KEY_PATH=/Users/you/path/to/localhost-key.pem
