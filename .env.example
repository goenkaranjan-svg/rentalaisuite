# Database Configuration
# PostgreSQL connection string
# For Docker: postgresql://postgres:postgres@localhost:5432/rental_ai_suite
# For local: postgresql://username:password@localhost:5432/database_name
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rental_ai_suite

# Session Configuration
# Generate a random secret for session encryption
# You can generate one with: openssl rand -base64 32
SESSION_SECRET=your-session-secret-here-change-this-in-production

# OIDC Authentication Configuration
# OIDC issuer URL (e.g., https://your-auth-provider.com/oidc)
ISSUER_URL=https://your-auth-provider.com/oidc
# Or use OIDC_ISSUER_URL instead
# OIDC_ISSUER_URL=https://your-auth-provider.com/oidc

# OIDC Client ID
CLIENT_ID=your-client-id-here

# Development-only auth bypass (never enable in production)
DEV_AUTH_BYPASS=false
# DEV_AUTH_BYPASS_USER_ID=dev-local-user
# DEV_AUTH_BYPASS_EMAIL=dev@localhost

# Auth Security / Verification
# Enforce verified email before login
REQUIRE_EMAIL_VERIFICATION=true
# Optional adaptive auth hardening
ENABLE_RISK_STEP_UP=true
# SESSION_IDLE_TIMEOUT_MS=1800000
# REQUIRE_CAPTCHA_ON_AUTH=false
# AUTH_ALLOW_COUNTRIES=US,CA
# AUTH_DENY_COUNTRIES=
# Enable passkey endpoint feature flags (full WebAuthn verification wiring required)
# ENABLE_PASSKEYS=false

# Auth Email Delivery (Resend)
AUTH_EMAIL_PROVIDER=resend
RESEND_API_KEY=re_3nyV8jEo_GKW52swk2CxZB1fdYdt5svbg
AUTH_EMAIL_FROM=no-reply@esourceincorp.com
PUBLIC_APP_URL=https://esourceincorp.com

# OpenAI Configuration (Optional - for AI features)
# AI_INTEGRATIONS_OPENAI_API_KEY=your-openai-api-key
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Listing publish endpoints (Optional - for one-click syndication publishing)
# LISTING_PUBLISH_ZILLOW_URL=https://your-zillow-feed-endpoint.example.com/listings
# LISTING_PUBLISH_ZILLOW_API_KEY=your-zillow-api-key
# LISTING_PUBLISH_APARTMENTS_URL=https://your-apartments-endpoint.example.com/listings
# LISTING_PUBLISH_APARTMENTS_API_KEY=your-apartments-api-key

# Server Configuration
PORT=5001
